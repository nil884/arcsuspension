ServerSignature Off
Options +FollowSymLinks -MultiViews

# ----------------------------------------------------------------------
# SECURITY HEADERS
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "https://www.arcsuspension.in"

    # Content Security Policy (CSP)
    Header set Content-Security-Policy "default-src 'self' https://jsonplaceholder.typicode.com https://widget.getbutton.io https://*.tawk.to https://www.youtube.com https://googleads.g.doubleclick.net https://checkout.razorpay.com https://api.razorpay.com/; frame-ancestors 'none'; connect-src 'self' https://onesignal.com https://*.tawk.to https://*.jsdelivr.net wss://*.tawk.to blob:; script-src 'self' blob: data: 'unsafe-inline' 'unsafe-eval' https://cdn.onesignal.com https://onesignal.com https://*.getbutton.io https://*.tawk.to https://www.googletagmanager.com https://www.google-analytics.com https://*.jsdelivr.net https://checkout.razorpay.com; object-src 'none'; style-src 'self' https://*.googleapis.com 'unsafe-inline' https://*.jsdelivr.net https://onesignal.com; img-src 'self' 'unsafe-inline' 'unsafe-eval' blob: data: https://*.tawk.to https://*.jsdelivr.net https://www.google-analytics.com https://www.surun.in; font-src 'self' https://*.gstatic.com https://*.tawk.to data:;"

    <FilesMatch "\.(css|png|js)$">
        Header set X-Content-Type-Options nosniff
    </FilesMatch>
</IfModule>

# ----------------------------------------------------------------------
# URL CANONICALIZATION (Force WWW and HTTPS)
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_HOST} !^www\..+$ [NC]
    RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# ----------------------------------------------------------------------
# PHP 7.2 SETTINGS (cPanel MultiPHP/CloudLinux)
# ----------------------------------------------------------------------
<IfModule php7_module>
   php_flag display_errors Off
   php_value max_execution_time 300
   php_value max_input_time 300
   php_value max_input_vars 100000
   php_value memory_limit 256M
   php_value post_max_size 32M
   php_value upload_max_filesize 16M
   php_flag zlib.output_compression On
</IfModule>

<IfModule lsapi_module>
   php_flag display_errors Off
   php_value max_execution_time 300
   php_value max_input_time 300
   php_value max_input_vars 100000
   php_value memory_limit 256M
   php_value post_max_size 32M
   php_value upload_max_filesize 16M
   php_flag zlib.output_compression On
</IfModule>

# ----------------------------------------------------------------------
# REWRITE RULES (URL Routing)
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Exclude directories and existing files
    RewriteCond %{REQUEST_URI} !^/admin
    RewriteCond %{REQUEST_URI} !^/vendor
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Static Routes
    RewriteRule ^blog/(.*)/(.*)/?$ blogdetail.php?cat=$1&urltitle=$2 [NC,L]
    RewriteRule ^review/(.*)/?$ review.php?prodid=$1 [NC,L]
    RewriteRule ^vendorproduct/(.*)/?$ vendorproduct.php?name=$1 [NC,L]
    RewriteRule ^companyproduct/(.*)/?$ companyproduct.php?name=$1 [NC,L]
    RewriteRule ^sitemap/?$ sitemap.php [NC,L]
    RewriteRule ^bloglist/(.*)/(.*)/?$ blog.php?id=$1 [NC,L]
    RewriteRule ^offer/?$ offer.php [NC,L]
    RewriteRule ^contact/?$ contact.php [NC,L]
    RewriteRule ^contactsuccess/?$ contanctsuccess.php [NC,L]
    RewriteRule ^smssuccess/?$ smssuccess.php [NC,L]
    RewriteRule ^search/?$ search.php [NC,L]
    RewriteRule ^wishview/?$ wishview.php [NC,L]
    RewriteRule ^cartview/?$ cartview.php [NC,L]
    RewriteRule ^compare/?$ compare.php [NC,L]

    # Subfolder Routes
    RewriteRule ^cancellation-return/?$ staticpages/cancellation.php [NC,L]
    RewriteRule ^terms-condition/?$ staticpages/termsconditions.php [NC,L]
    RewriteRule ^vendor-terms-condition/?$ staticpages/vendor_term.php [NC,L]
    RewriteRule ^privacy-policy/?$ staticpages/privacy.php [NC,L]
    RewriteRule ^faq/?$ staticpages/faq.php [NC,L]
    RewriteRule ^about-us/?$ staticpages/about.php [NC,L]
    RewriteRule ^international_shipping/?$ staticpages/international_shipping.php [NC,L]

    # Account & Payment Routes
    RewriteRule ^login/?$ member-login.php [NC,L]
    RewriteRule ^register/?$ member-register.php [NC,L]
    RewriteRule ^checkout/?$ order/order_process.php [NC,L]
    RewriteRule ^payment/(.*)/?$ order/proceedpayment.php?transid=$1 [NC,L]
    RewriteRule ^paymentresponse/?$ order/paymentresponse.php [NC,L]
    RewriteRule ^paymentend/(.*)/?$ order/completion_display.php?transid=$1 [NC,L]

    RewriteRule ^account/bankdetails/?$ account/bankdetail.php [NC,L]
    RewriteRule ^account/taxation/?$ account/taxdetails.php [NC,L]
    RewriteRule ^account/myreviews/?$ account/review.php [NC,L]
    RewriteRule ^account/myorders/?$ account/myorder.php [NC,L]
    RewriteRule ^account/myaddresses/?$ account/order_adress.php [NC,L]
    RewriteRule ^account/order/(.*)/?$ account/order_detail.php?transid=$1 [NC,L]
    RewriteRule ^logout/?$ logout.php [NC,L]

    # Product Detail
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/admin
    RewriteCond %{REQUEST_URI} !^/vendors
    RewriteCond %{QUERY_STRING} !blog [NC]
    RewriteRule ^([^/.]+)/([^/.]+)/([^/.]+)/([^/.]+)/?$ product-detail.php?parent=$1&master=$2&sub=$3&urltitle=$4 [L,QSA]

    # Product Subcategory
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/admin
    RewriteCond %{REQUEST_URI} !^/vendors
    RewriteCond %{QUERY_STRING} !blog [NC]
    RewriteRule ^([^/.]+)/([^/.]+)/([^/.]+)/?$ product-subcategorywise.php?parent=$1&master=$2&urltitle=$3 [L,QSA]

    # Product Master
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/admin
    RewriteCond %{REQUEST_URI} !^/vendors
    RewriteCond %{QUERY_STRING} !blog [NC]
    RewriteRule ^([^/.]+)/([^/.]+)/?$ product-masterwise.php?parent=$1&urltitle=$2 [L,QSA]

    # Product Category
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/admin
    RewriteCond %{REQUEST_URI} !^/vendors
    RewriteCond %{QUERY_STRING} !^blog [NC]
    RewriteRule ^([^/.]+)/?$ product-parentwise.php?urltitle=$1 [L,QSA]
</IfModule>

# BEGIN cPanel-generated php ini directives, do not edit
<IfModule php8_module>
   php_flag log_errors On
   php_flag display_errors On
   php_value error_reporting E_ALL
   php_value error_log "/home/myarc/public_html/arcsuspension.in/error.log"
</IfModule>

<IfModule lsapi_module>
   php_flag log_errors On
   php_flag display_errors On
   php_value error_reporting E_ALL
   php_value error_log "/home/myarc/public_html/arcsuspension.in/error.log"
</IfModule>
# END cPanel-generated php ini directives

# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php72 .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler